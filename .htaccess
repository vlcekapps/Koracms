<IfModule mod_expires.c>
    ExpiresActive On
    ExpiresByType text/html M0
</IfModule>
Options -Indexes

# Ochrana konfiguračních souborů
<FilesMatch "^(config|db|auth)\.php$">
    Require all denied
</FilesMatch>

# Ochrana vývojových a CI konfiguračních souborů
<FilesMatch "^(composer\.(json|lock)|phpstan\.neon\.dist|\.php-cs-fixer\.dist\.php)$">
    Require all denied
</FilesMatch>

# Blokovat ploché datové soubory
<FilesMatch "^(?!robots\.txt$).*\.(inc|txt|log|sql|bak|sh|cfg|env)$">
    Require all denied
</FilesMatch>

# Blokovat přístup k .env a .git
<FilesMatch "^\.env">
    Require all denied
</FilesMatch>
<IfModule mod_rewrite.c>
    RewriteRule ^\.git - [F,L]
    RewriteRule ^\.github - [F,L]
    RewriteRule ^\.claude - [F,L]
    RewriteRule ^\.codex - [F,L]
    RewriteRule ^\.cursor - [F,L]
    RewriteRule ^vendor/ - [F,L]
    RewriteRule ^node_modules/ - [F,L]
</IfModule>

# Bezpečnostní hlavičky
<IfModule mod_setenvif.c>
    SetEnvIfNoCase Request_URI "(^|/)media/preview\.php$" KORA_MEDIA_PREVIEW=1
    SetEnvIfNoCase User-Agent "(facebookexternalhit|facebot|twitterbot|linkedinbot|slackbot|discordbot|whatsapp|telegrambot|pinterest|vkshare|skypeuripreview|embedly|quora link preview|outbrain|applebot)" KORA_SOCIAL_CRAWLER=1
    SetEnvIfNoCase Request_URI "(^|/)(csp-report|health|confirm_email|subscribe_confirm|unsubscribe|newsletter_widget_subscribe|reset_password|public_logout)\.php($|\?)" KORA_NO_STORE_NO_INDEX=1 !KORA_SOCIAL_CRAWLER
    SetEnvIfNoCase Request_URI "(^|/)reservations/cancel_booking\.php($|\?)" KORA_NO_STORE_NO_INDEX=1 !KORA_SOCIAL_CRAWLER
    SetEnvIfNoCase Request_URI "(^|/)admin/logout\.php($|\?)" KORA_NO_STORE_NO_INDEX=1 !KORA_SOCIAL_CRAWLER
</IfModule>
<IfModule mod_headers.c>
    Header always set X-Content-Type-Options "nosniff"
    Header always set X-Frame-Options "SAMEORIGIN" env=KORA_MEDIA_PREVIEW
    Header always set X-Frame-Options "DENY" env=!KORA_MEDIA_PREVIEW
    Header always set X-XSS-Protection "0"
    Header always set X-Download-Options "noopen"
    Header always setifempty Referrer-Policy "same-origin"
    Header unset Set-Cookie env=KORA_SOCIAL_CRAWLER
    Header always unset Set-Cookie env=KORA_SOCIAL_CRAWLER
    Header unset Cache-Control env=KORA_SOCIAL_CRAWLER
    Header always unset Cache-Control env=KORA_SOCIAL_CRAWLER
    Header always set Cache-Control "public, max-age=300, s-maxage=300" env=KORA_SOCIAL_CRAWLER
    Header unset Pragma env=KORA_SOCIAL_CRAWLER
    Header always unset Pragma env=KORA_SOCIAL_CRAWLER
    Header unset Expires env=KORA_SOCIAL_CRAWLER
    Header always unset Expires env=KORA_SOCIAL_CRAWLER
    Header always set Cache-Control "no-store, max-age=0" env=KORA_NO_STORE_NO_INDEX
    Header merge Vary "User-Agent" env=KORA_SOCIAL_CRAWLER
    Header always set Pragma "no-cache" env=KORA_NO_STORE_NO_INDEX
    Header always set Expires "0" env=KORA_NO_STORE_NO_INDEX
    Header always set X-Robots-Tag "noindex, nofollow, noarchive" env=KORA_NO_STORE_NO_INDEX
    Header always set Referrer-Policy "no-referrer" env=KORA_NO_STORE_NO_INDEX
</IfModule>

<IfModule mod_rewrite.c>
    RewriteEngine On

    # Přílohy formulářů se stahují jen přes chráněný admin endpoint
    RewriteRule ^uploads/forms/ - [F,L,NC]
    # Staré databázové zálohy nesmí být přímo dostupné z webu
    RewriteRule ^uploads/backups/ - [F,L,NC]
    # Fotografie galerie se zobrazují jen přes gallery/image.php
    RewriteRule ^uploads/gallery/ - [F,L,NC]
    # Obrázky míst se zobrazují jen přes places/image.php
    RewriteRule ^uploads/places/ - [F,L,NC]
    # Podcast audio a artwork se vydávají jen přes podcast/*.php endpointy
    RewriteRule ^uploads/podcasts/ - [F,L,NC]
    # SVG z knihovny médií se nikdy neservírují přímo z uploads/media
    RewriteRule ^uploads/media/.+\.svg$ - [F,L,NC]

    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteRule ^robots\.txt$ robots.php [L,QSA,NC]

    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteRule ^sitemap\.xml$ sitemap.php [L,QSA,NC]

    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteRule ^authors/?$ authors/index.php [L,QSA,NC]
    RewriteRule ^author/([a-z0-9\-]+)/?$ author.php?slug=$1 [L,QSA,NC]
    RewriteRule ^blog/([a-z0-9\-]+)/?$ blog/article.php?slug=$1 [L,QSA,NC]
    RewriteRule ^board/([a-z0-9\-]+)/?$ board/document.php?slug=$1 [L,QSA,NC]
    RewriteRule ^downloads/([a-z0-9\-]+)/?$ downloads/item.php?slug=$1 [L,QSA,NC]
    RewriteRule ^events/([a-z0-9\-]+)\.ics$ events/ics.php?slug=$1 [L,QSA,NC]
    RewriteRule ^events/([a-z0-9\-]+)/?$ events/event.php?slug=$1 [L,QSA,NC]
    RewriteRule ^faq/([a-z0-9\-]+)/?$ faq/item.php?slug=$1 [L,QSA,NC]
    RewriteRule ^forms/([a-z0-9\-]+)/?$ forms/index.php?slug=$1 [L,QSA,NC]
    RewriteRule ^food/card/([a-z0-9\-]+)/?$ food/card.php?slug=$1 [L,QSA,NC]
    RewriteRule ^gallery/album/([a-z0-9\-]+)/?$ gallery/album.php?slug=$1 [L,QSA,NC]
    RewriteRule ^gallery/photo/([a-z0-9\-]+)/?$ gallery/photo.php?slug=$1 [L,QSA,NC]
    RewriteRule ^news/([a-z0-9\-]+)/?$ news/article.php?slug=$1 [L,QSA,NC]
    RewriteRule ^polls/([a-z0-9\-]+)/?$ polls/index.php?slug=$1 [L,QSA,NC]
    RewriteRule ^places/([a-z0-9\-]+)/?$ places/place.php?slug=$1 [L,QSA,NC]
    RewriteRule ^podcast/([a-z0-9\-]+)/([a-z0-9\-]+)/?$ podcast/episode.php?show=$1&slug=$2 [L,QSA,NC]
    RewriteRule ^podcast/([a-z0-9\-]+)/?$ podcast/show.php?slug=$1 [L,QSA,NC]

    # Multi-blog catch-all (MUSÍ být poslední – dynamické blog slugy)
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteRule ^([a-z0-9\-]+)/serie/([a-z0-9\-]+)/?$ blog_router.php?blog_slug=$1&series_slug=$2 [L,QSA,NC]

    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteRule ^([a-z0-9\-]+)/stranka/([a-z0-9\-]+)/?$ blog_router.php?blog_slug=$1&page_slug=$2 [L,QSA,NC]

    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteRule ^([a-z0-9\-]+)/([a-z0-9\-]+)/?$ blog_router.php?blog_slug=$1&slug=$2 [L,QSA,NC]

    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteRule ^([a-z0-9\-]+)/?$ blog_router.php?blog_slug=$1 [L,QSA,NC]
</IfModule>

# Volitelné: HTTPS redirect (odkomentujte pokud máte SSL)
# RewriteEngine On
# RewriteCond %{HTTPS} off
# RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]
